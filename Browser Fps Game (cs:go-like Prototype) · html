<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>BEBA FPS</title>
<style>
body{margin:0;overflow:hidden;background:black;font-family:Arial}
#hud{position:fixed;top:10px;left:10px;color:white;z-index:2}
#crosshair{position:fixed;top:50%;left:50%;width:10px;height:10px;margin-left:-5px;margin-top:-5px;border:2px solid white;border-radius:50%}
#menu,#death{position:fixed;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:black;color:white;z-index:10}
button{padding:10px 20px;font-size:18px;cursor:pointer}
</style>
</head>
<body>

<div id="menu">
<h1>BEBA FPS</h1>
<button onclick="startGame()">PLAY</button>
</div>

<div id="death" style="display:none">
<h1 style="color:red">YOU DIED</h1>
<button onclick="respawn()">RESPAWN</button>
</div>

<div id="hud">
HP: <span id="hp">100</span> |
Ammo: <span id="ammo">30</span> |
Kills: <span id="kills">0</span> |
Weapon: <span id="weaponName">Pistol</span>
</div>
<div id="crosshair"></div>

<script src="https://cdn.jsdelivr.net/npm/three@0.152.2/build/three.min.js"></script>

<script>
let scene=new THREE.Scene();
let camera=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,0.1,1000);
let renderer=new THREE.WebGLRenderer();
renderer.setSize(innerWidth,innerHeight);
document.body.appendChild(renderer.domElement);

let gameStarted=false;
let hp=100,kills=0,isDead=false;
let keys={};
let enemies=[];
let walls=[];

let weapons=[];
let currentWeapon=0;
let weaponGroup;
let ammo=30;
let isReloading=false;

function createHands(){
 let hands=new THREE.Group();
 let handMat=new THREE.MeshStandardMaterial({color:0xffcc99});

 let leftHand=new THREE.Mesh(new THREE.BoxGeometry(0.2,0.3,0.2),handMat);
 leftHand.position.set(-0.25,-0.35,-0.8);

 let rightHand=new THREE.Mesh(new THREE.BoxGeometry(0.2,0.3,0.2),handMat);
 rightHand.position.set(0.25,-0.35,-0.8);

 hands.add(leftHand);
 hands.add(rightHand);
 return hands;
}

function createWeaponModel(color){
 let g=new THREE.BoxGeometry(0.25,0.15,0.8);
 let m=new THREE.MeshStandardMaterial({color});
 let gun=new THREE.Mesh(g,m);
 gun.position.set(0,-0.35,-0.9);
 return gun;
}

function Weapon(name,damage,spread,maxAmmo,color,sound){
 this.name=name;
 this.damage=damage;
 this.spread=spread;
 this.maxAmmo=maxAmmo;
 this.color=color;
 this.sound=sound;
}

weapons.push(new Weapon("Pistol",25,0.02,12,0x888888,"https://actions.google.com/sounds/v1/guns/pistol_shot.ogg"));
weapons.push(new Weapon("AK-47",12,0.05,30,0x553311,"https://actions.google.com/sounds/v1/guns/rifle_shot.ogg"));
weapons.push(new Weapon("SMG",8,0.08,40,0x222222,"https://actions.google.com/sounds/v1/guns/medium_gunshot.ogg"));
weapons.push(new Weapon("Shotgun",40,0.15,8,0x333333,"https://actions.google.com/sounds/v1/guns/shotgun.ogg"));
weapons.push(new Weapon("Sniper",90,0.001,5,0x000000,"https://actions.google.com/sounds/v1/guns/sniper_rifle.ogg"));

function updateWeapon(){
 if(weaponGroup) camera.remove(weaponGroup);

 let w=weapons[currentWeapon];
 weaponGroup=new THREE.Group();

 let hands=createHands();
 let gun=createWeaponModel(w.color);

 weaponGroup.add(hands);
 weaponGroup.add(gun);
 camera.add(weaponGroup);

 document.getElementById("weaponName").innerText=w.name;
 document.getElementById("ammo").innerText=ammo+"/"+w.maxAmmo;
}

let light=new THREE.DirectionalLight(0xffffff,1);
light.position.set(5,10,5);
scene.add(light);

let floor=new THREE.Mesh(new THREE.PlaneGeometry(50,50),new THREE.MeshStandardMaterial({color:0x333333}));
floor.rotation.x=-Math.PI/2;
scene.add(floor);

function wall(x,z,sx,sz){
 let w=new THREE.Mesh(new THREE.BoxGeometry(sx,2,sz),new THREE.MeshStandardMaterial({color:0x777777}));
 w.position.set(x,1,z);
 scene.add(w);
 walls.push(w);
}

wall(0,-10,20,1);
wall(0,10,20,1);
wall(-10,0,1,20);
wall(10,0,1,20);
wall(3,0,3,3);
wall(-3,-3,3,3);

camera.position.set(0,1.6,5);

function spawnEnemy(){
 let e=new THREE.Mesh(new THREE.BoxGeometry(1,1.5,1),new THREE.MeshStandardMaterial({color:0xff0000}));
 e.position.set(Math.random()*10-5,0.75,Math.random()*10-5);
 e.hp=100;
 scene.add(e);
 enemies.push(e);
}
setInterval(()=>{if(gameStarted)spawnEnemy()},3000);

document.addEventListener('keydown',e=>{
 keys[e.key]=true;
 if(e.key>='1' && e.key<='5'){
  currentWeapon=parseInt(e.key)-1;
  ammo=weapons[currentWeapon].maxAmmo;
  updateWeapon();
 }
 if(e.key==='r')reload();
});
document.addEventListener('keyup',e=>keys[e.key]=false);
document.body.addEventListener('click',shoot);

function playSound(url){
 let a=new Audio(url);
 a.volume=0.4;
 a.play();
}

function reload(){
 if(isReloading) return;
 let w=weapons[currentWeapon];
 if(ammo===w.maxAmmo) return;

 isReloading=true;

 let t=0;
 let duration=20;

 if(w.name==="AK-47") duration=35;
 if(w.name==="Sniper") duration=45;
 if(w.name==="Shotgun") duration=28;
 if(w.name==="SMG") duration=22;
 if(w.name==="Pistol") duration=18;

 let interval=setInterval(()=>{
  if(weaponGroup){
   if(w.name==="AK-47"){
    weaponGroup.position.y=Math.sin(t*0.3)*0.08;
    weaponGroup.rotation.z=Math.sin(t*0.2)*0.15;
    weaponGroup.rotation.x=0.25;
   } else if(w.name==="Sniper"){
    weaponGroup.position.y=Math.sin(t*0.2)*0.03;
    weaponGroup.rotation.x=0.4;
   } else {
    weaponGroup.position.y=Math.sin(t*0.4)*0.05;
    weaponGroup.rotation.x=0.2;
   }
  }

  t++;

  if(t>duration){
   clearInterval(interval);
   ammo=w.maxAmmo;
   isReloading=false;

   if(weaponGroup){
    weaponGroup.position.set(0,0,0);
    weaponGroup.rotation.set(0,0,0);
   }
  }
 },30);
}

function shoot(){
 if(!gameStarted||isDead||isReloading)return;
 if(ammo<=0) return;

 let w=weapons[currentWeapon];
 ammo--;
 document.getElementById("ammo").innerText=ammo+"/"+w.maxAmmo;

 playSound(w.sound);

 if(weaponGroup){
  weaponGroup.position.z-=0.05;
  setTimeout(()=>weaponGroup.position.z+=0.05,80);
 }

 let ray=new THREE.Raycaster();
 ray.setFromCamera(new THREE.Vector2((Math.random()-0.5)*w.spread,(Math.random()-0.5)*w.spread),camera);

 enemies.forEach(e=>{
  let hit=ray.intersectObject(e);
  if(hit.length){
   e.hp-=w.damage;
   if(e.hp<=0){
    scene.remove(e);
    enemies=enemies.filter(x=>x!==e);
    kills++;
    document.getElementById("kills").innerText=kills;
   }
  }
 });
}

function move(){
 let speed=0.08;
 let nx=camera.position.x;
 let nz=camera.position.z;

 if(keys['w'])nz-=speed;
 if(keys['s'])nz+=speed;
 if(keys['a'])nx-=speed;
 if(keys['d'])nx+=speed;

 let blocked=walls.some(w=>Math.abs(nx-w.position.x)<1.2&&Math.abs(nz-w.position.z)<1.2);
 if(!blocked){camera.position.x=nx;camera.position.z=nz;}
}

function updateEnemies(){
 enemies.forEach(e=>{
  let dx=camera.position.x-e.position.x;
  let dz=camera.position.z-e.position.z;
  let d=Math.sqrt(dx*dx+dz*dz);

  e.position.x+=dx/d*0.02;
  e.position.z+=dz/d*0.02;

  if(d<1.2 && !isDead){
   hp-=0.3;
   document.getElementById("hp").innerText=Math.max(0,Math.floor(hp));
   if(hp<=0)die();
  }
 });
}

function die(){
 isDead=true;
 document.getElementById("death").style.display="flex";
}

function respawn(){
 hp=100;
 isDead=false;
 camera.position.set(0,1.6,5);
 document.getElementById("death").style.display="none";
 document.getElementById("hp").innerText=hp;
}

function loop(){
 if(!gameStarted||isDead)return;
 move();
 updateEnemies();
 renderer.render(scene,camera);
 requestAnimationFrame(loop);
}

function startGame(){
 document.getElementById("menu").style.display="none";
 gameStarted=true;
 updateWeapon();
 loop();
}
</script>

</body>
</html>
